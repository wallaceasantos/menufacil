generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String           @unique @db.VarChar(255)
  name                String           @db.VarChar(255)
  type                String           @db.VarChar(100)
  email               String           @unique @db.VarChar(255)
  plan                String           @default("basico") @db.VarChar(50)
  status              String           @default("active") @db.VarChar(50)
  paymentStatus       String           @default("paid") @map("payment_status") @db.VarChar(50)
  overdueDays         Int?             @default(0) @map("overdue_days")
  // ⚠️ Campos históricos — guardam IDs do Mercado Pago (não Asaas)
  // Renomeie para mpCustomerId / mpSubscriptionId em nova migração
  asaasCustomerId     String?          @map("asaas_customer_id") @db.VarChar(255)
  asaasSubscriptionId String?          @map("asaas_subscription_id") @db.VarChar(255)
  description      String?
  address          String?
  phone            String?          @db.VarChar(50)
  ownerCpfCnpj     String?          @map("owner_cpf_cnpj") @db.VarChar(14)
  ownerFirstName   String?          @map("owner_first_name") @db.VarChar(60)
  ownerLastName    String?          @map("owner_last_name") @db.VarChar(60)
  billingEmail     String?          @map("billing_email") @db.VarChar(255)
  billingPhone     String?          @map("billing_phone") @db.VarChar(50)
  billingPostalCode String?         @map("billing_postal_code") @db.VarChar(9)
  billingAddressNumber String?      @map("billing_address_number") @db.VarChar(10)
  deliveryFee      Decimal?         @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  minOrder         Decimal?         @default(0) @map("min_order") @db.Decimal(10, 2)
  openingHours     DateTime?        @map("opening_hours") @db.Time(6)
  closingHours     DateTime?        @map("closing_hours") @db.Time(6)
  logoUrl          String?          @map("logo_url")
  bannerUrl        String?          @map("banner_url")
  customDomain     String?          @map("custom_domain") @db.VarChar(255)
  domainVerified   Boolean?         @default(false) @map("domain_verified")
  domainToken      String?          @map("domain_token") @db.VarChar(64)
  platformRating   Int?             @map("platform_rating") @db.SmallInt
  platformComment  String?          @map("platform_comment") @db.VarChar(500)
  latitude         Decimal?         @db.Decimal(10, 7)
  longitude        Decimal?         @db.Decimal(10, 7)
  subscriptionStatus String?   @default("none") @map("subscription_status") @db.VarChar(50)
  cardLastFour       String?   @map("card_last_four") @db.VarChar(4)
  nextBillingDate    DateTime? @map("next_billing_date") @db.Date
  lastBillingDate    DateTime? @map("last_billing_date") @db.Date
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  categories         Category[]
  inventoryBatches InventoryBatch[]
  inventoryItems   InventoryItem[]
  orders           Order[]
  products         Product[]
  purchaseOrders   PurchaseOrder[]
  stockMovements   StockMovement[]
  suppliers        Supplier[]
  supportTickets   SupportTicket[]
  users            User[]
  whatsAppConfig   WhatsAppConfig?
  paymentConfig    PaymentConfig?
  invoices         Invoice[]
  planChangeLogs   PlanChangeLog[]
  customers        Customer[]
  deliveryZones    DeliveryZone[]
  printerConfigs   PrinterConfig[]
  printJobs        PrintJob[]
  discounts        Discount[]
  pushSubscriptions PushSubscription[]
  invites          Invite[]

  @@map("tenants")
}

model User {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String?         @map("tenant_id") @db.Uuid
  name         String          @db.VarChar(255)
  email        String          @db.VarChar(255)
  passwordHash String          @map("password_hash") @db.VarChar(255)
  role         String          @default("tenant") @db.VarChar(50)
  tenantRole   String?         @default("dono") @map("tenant_role") @db.VarChar(50)
  createdAt    DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tickets      SupportTicket[]
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, email])
  @@index([email], map: "idx_users_email")
  @@index([tenantId], map: "idx_users_tenant_id")
  @@map("users")
}

model Category {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(100)
  sortOrder Int?      @default(0) @map("sort_order")
  startTime String?   @map("start_time") @db.VarChar(5)
  endTime   String?   @map("end_time") @db.VarChar(5)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products  Product[]

  @@index([tenantId], map: "idx_categories_tenant_id")
  @@map("categories")
}

model Product {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String                @map("tenant_id") @db.Uuid
  categoryId          String?               @map("category_id") @db.Uuid
  name                String                @db.VarChar(255)
  description         String?
  price               Decimal               @db.Decimal(10, 2)
  imageUrl            String?               @map("image_url")
  productType         String                @default("simple") @map("product_type") @db.VarChar(50)
  isActive            Boolean?              @default(true) @map("is_active")
  autoDeductStock     Boolean?              @default(true) @map("auto_deduct_stock")
  createdAt           DateTime?             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  orderItems          OrderItem[]
  product_complements product_complements[]
  productComponents   ProductComponent[]
  productChoiceGroups ProductChoiceGroup[]
  recipes             ProductRecipe[]
  category            Category?             @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([categoryId], map: "idx_products_category_id")
  @@index([tenantId], map: "idx_products_tenant_id")
  @@map("products")
}

model InventoryItem {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  name           String              @db.VarChar(255)
  unit           String              @default("un") @db.VarChar(20)
  currentStock   Decimal             @default(0) @map("current_stock") @db.Decimal(12, 3)
  minStock       Decimal             @default(0) @map("min_stock") @db.Decimal(12, 3)
  averageCost    Decimal?            @default(0) @map("average_cost") @db.Decimal(10, 4)
  referenceCost  Decimal?            @default(0) @map("reference_cost") @db.Decimal(10, 4)
  markup         Decimal?            @default(2.50) @db.Decimal(5, 2)
  createdAt      DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  batches              InventoryBatch[]
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  recipes              ProductRecipe[]
  purchaseItems        PurchaseOrderItem[]
  stockMovements       StockMovement[]
  productComponents    ProductComponent[]
  productChoiceOptions ProductChoiceOption[]

  @@index([tenantId], map: "idx_inventory_items_tenant_id")
  @@map("inventory_items")
}

model Supplier {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  name           String           @db.VarChar(255)
  phone          String?          @db.VarChar(50)
  email          String?          @db.VarChar(255)
  address        String?
  createdAt      DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  batches        InventoryBatch[]
  purchaseOrders PurchaseOrder[]
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("suppliers")
}

model PurchaseOrder {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String              @map("tenant_id") @db.Uuid
  supplierId String?             @map("supplier_id") @db.Uuid
  status     String              @default("pending") @db.VarChar(50)
  totalCost  Decimal             @default(0) @map("total_cost") @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  receivedAt DateTime?           @map("received_at") @db.Timestamptz(6)
  updatedAt  DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  batches    InventoryBatch[]
  items      PurchaseOrderItem[]
  supplier   Supplier?           @relation(fields: [supplierId], references: [id], onUpdate: NoAction)
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_purchase_orders_tenant_id")
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId   String        @map("purchase_order_id") @db.Uuid
  inventoryItemId   String        @map("inventory_item_id") @db.Uuid
  quantity          Decimal       @db.Decimal(12, 3)
  unitCost          Decimal       @map("unit_cost") @db.Decimal(10, 4)
  expirationDate    DateTime?     @map("expiration_date") @db.Date
  manufacturingDate DateTime?     @map("manufacturing_date") @db.Date
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([purchaseOrderId], map: "idx_purchase_order_items_order_id")
  @@map("purchase_order_items")
}

model InventoryBatch {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  inventoryItemId   String          @map("inventory_item_id") @db.Uuid
  purchaseOrderId   String?         @map("purchase_order_id") @db.Uuid
  supplierId        String?         @map("supplier_id") @db.Uuid
  quantity          Decimal         @db.Decimal(12, 3)
  remainingQuantity Decimal         @map("remaining_quantity") @db.Decimal(12, 3)
  unitCost          Decimal         @map("unit_cost") @db.Decimal(10, 4)
  expirationDate    DateTime?       @map("expiration_date") @db.Date
  manufacturingDate DateTime?       @map("manufacturing_date") @db.Date
  createdAt         DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  inventoryItem     InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  purchaseOrder     PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction)
  supplier          Supplier?       @relation(fields: [supplierId], references: [id], onUpdate: NoAction)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stockMovements    StockMovement[]

  @@index([expirationDate], map: "idx_inventory_batches_expiration")
  @@index([inventoryItemId], map: "idx_inventory_batches_item_id")
  @@map("inventory_batches")
}

model ProductRecipe {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  inventoryItemId String        @map("inventory_item_id") @db.Uuid
  quantity        Decimal       @db.Decimal(12, 3)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([productId, inventoryItemId])
  @@index([productId], map: "idx_product_recipes_product_id")
  @@map("product_recipes")
}

model StockMovement {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  inventoryItemId  String          @map("inventory_item_id") @db.Uuid
  inventoryBatchId String?         @map("inventory_batch_id") @db.Uuid
  type             String          @db.VarChar(50)
  quantity         Decimal         @db.Decimal(12, 3)
  reason           String?
  orderId          String?         @map("order_id") @db.Uuid
  createdAt        DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  inventoryBatch   InventoryBatch? @relation(fields: [inventoryBatchId], references: [id], onUpdate: NoAction)
  inventoryItem    InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([inventoryItemId], map: "idx_stock_movements_item_id")
  @@index([tenantId], map: "idx_stock_movements_tenant_id")
  @@map("stock_movements")
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  customerName    String      @map("customer_name") @db.VarChar(255)
  customerPhone   String      @map("customer_phone") @db.VarChar(50)
  status          String      @default("pending") @db.VarChar(50)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress String?     @map("delivery_address")
  paymentMethod   String?     @map("payment_method") @db.VarChar(100)
  mpPaymentId     String?     @map("mp_payment_id") @db.VarChar(50)
  mpPaymentStatus String?     @map("mp_payment_status") @db.VarChar(50)
  mpPixPayload    String?     @map("mp_pix_payload") @db.Text
  mpPixQrCode     String?     @map("mp_pix_qr_code") @db.Text
  stockDeducted   Boolean?    @default(false) @map("stock_deducted")
  customerId      String?     @map("customer_id") @db.Uuid
  rating          Int?        @db.SmallInt
  ratingComment   String?     @map("rating_comment")
  ratedAt         DateTime?   @map("rated_at") @db.Timestamptz(6)
  createdAt       DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items           OrderItem[]
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_orders_status")
  @@index([tenantId], map: "idx_orders_tenant_id")
  @@index([tenantId, createdAt(sort: Desc)], map: "idx_orders_tenant_id_created_at")
  @@map("orders")
}

model OrderItem {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId                String                   @map("order_id") @db.Uuid
  productId              String                   @map("product_id") @db.Uuid
  quantity               Int
  unitPrice              Decimal                  @map("unit_price") @db.Decimal(10, 2)
  notes                  String?
  order_item_complements order_item_complements[]
  orderItemComponents    OrderItemComponent[]
  orderItemChoices       OrderItemChoice[]
  order                  Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product                Product                  @relation(fields: [productId], references: [id], onUpdate: NoAction)

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model ProductComponent {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String         @map("product_id") @db.Uuid
  name            String         @db.VarChar(255)
  inventoryItemId String?        @map("inventory_item_id") @db.Uuid
  quantity        Decimal        @default(1) @db.Decimal(12, 3)
  price           Decimal        @default(0) @db.Decimal(10, 2)
  includedInPrice Boolean        @default(true) @map("included_in_price")
  deductStock     Boolean        @default(true) @map("deduct_stock")
  isDefault       Boolean        @default(true) @map("is_default")
  sortOrder       Int?           @default(0) @map("sort_order")
  createdAt       DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onUpdate: NoAction)

  @@index([productId], map: "idx_product_components_product_id")
  @@map("product_components")
}

model ProductChoiceGroup {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String                @map("product_id") @db.Uuid
  name        String                @db.VarChar(255)
  minChoices  Int                   @default(0) @map("min_choices")
  maxChoices  Int                   @default(1) @map("max_choices")
  required    Boolean               @default(false)
  sortOrder   Int?                  @default(0) @map("sort_order")
  createdAt   DateTime?             @default(now()) @map("created_at") @db.Timestamptz(6)
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  options     ProductChoiceOption[]

  @@index([productId], map: "idx_product_choice_groups_product_id")
  @@map("product_choice_groups")
}

model ProductChoiceOption {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  choiceGroupId   String             @map("choice_group_id") @db.Uuid
  name            String             @db.VarChar(255)
  inventoryItemId String?            @map("inventory_item_id") @db.Uuid
  quantity        Decimal            @default(1) @db.Decimal(12, 3)
  price           Decimal            @default(0) @db.Decimal(10, 2)
  includedInPrice Boolean            @default(false) @map("included_in_price")
  deductStock     Boolean            @default(true) @map("deduct_stock")
  isDefault       Boolean            @default(false) @map("is_default")
  sortOrder       Int?               @default(0) @map("sort_order")
  createdAt       DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  choiceGroup     ProductChoiceGroup @relation(fields: [choiceGroupId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onUpdate: NoAction)

  @@index([choiceGroupId], map: "idx_product_choice_options_group_id")
  @@map("product_choice_options")
}

model OrderItemComponent {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId     String    @map("order_item_id") @db.Uuid
  componentId     String    @map("component_id") @db.Uuid
  name            String    @db.VarChar(255)
  quantity        Int
  unitPrice       Decimal   @map("unit_price") @db.Decimal(10, 2)
  inventoryItemId String?   @map("inventory_item_id") @db.Uuid
  deductStock     Boolean   @default(true) @map("deduct_stock")
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderItemId], map: "idx_order_item_components_order_item_id")
  @@map("order_item_components")
}

model OrderItemChoice {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId     String    @map("order_item_id") @db.Uuid
  choiceGroupId   String    @map("choice_group_id") @db.Uuid
  choiceGroupName String    @map("choice_group_name") @db.VarChar(255)
  optionId        String    @map("option_id") @db.Uuid
  optionName      String    @map("option_name") @db.VarChar(255)
  quantity        Int
  unitPrice       Decimal   @map("unit_price") @db.Decimal(10, 2)
  inventoryItemId String?   @map("inventory_item_id") @db.Uuid
  deductStock     Boolean   @default(true) @map("deduct_stock")
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderItemId], map: "idx_order_item_choices_order_item_id")
  @@map("order_item_choices")
}

model SupportTicket {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  subject     String          @db.VarChar(255)
  description String
  status      String          @default("open") @db.VarChar(50)
  createdAt   DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages    TicketMessage[]

  @@index([tenantId], map: "idx_support_tickets_tenant_id")
  @@map("support_tickets")
}

model TicketMessage {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String             @map("ticket_id") @db.Uuid
  senderRole  String             @map("sender_role") @db.VarChar(50)
  message     String
  createdAt   DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket      SupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attachments TicketAttachment[]

  @@index([ticketId], map: "idx_ticket_messages_ticket_id")
  @@map("ticket_messages")
}

model TicketAttachment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String        @map("message_id") @db.Uuid
  filename  String        @db.VarChar(255)
  url       String
  mimeType  String?       @map("mime_type") @db.VarChar(100)
  size      Int?
  createdAt DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  message   TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([messageId], map: "idx_ticket_attachments_message_id")
  @@map("ticket_attachments")
}

model Invoice {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  amount          Decimal   @db.Decimal(10, 2)
  dueDate         DateTime  @map("due_date") @db.Date
  status          String    @default("pending") @db.VarChar(50)
  paymentMethod   String?   @map("payment_method") @db.VarChar(50)
  description     String?
  documentUrl     String?   @map("document_url")
  externalId      String?   @map("external_id")
  paidAt          DateTime? @map("paid_at") @db.Timestamptz(6)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_invoices_tenant_id")
  @@index([tenantId, dueDate], map: "idx_invoices_tenant_due_date")
  @@map("invoices")
}

model GlobalAnnouncement {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message   String
  isActive  Boolean?  @default(true) @map("is_active")
