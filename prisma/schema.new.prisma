// schema.prisma
// Modelo completo do MenuFácil: multi-tenant, cardápio, pedidos, estoque, fornecedores e suporte.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String          @id @default(uuid()) @db.Uuid
  slug            String          @unique @db.VarChar(255)
  name            String          @db.VarChar(255)
  type            String          @db.VarChar(100)
  email           String          @unique @db.VarChar(255)
  plan            String          @default("basico") @db.VarChar(50)
  status          String          @default("active") @db.VarChar(50)
  paymentStatus   String          @default("paid") @map("payment_status") @db.VarChar(50)
  overdueDays     Int?            @default(0) @map("overdue_days")

  // Configurações da loja pública
  description     String?         @db.Text
  address         String?         @db.Text
  phone           String?         @db.VarChar(50)
  deliveryFee     Decimal?        @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  minOrder        Decimal?        @default(0) @map("min_order") @db.Decimal(10, 2)
  openingHours    DateTime?       @db.Time(0) @map("opening_hours")
  closingHours    DateTime?       @db.Time(0) @map("closing_hours")
  logoUrl         String?         @map("logo_url") @db.Text
  bannerUrl       String?         @map("banner_url") @db.Text
  customDomain    String?         @map("custom_domain") @db.VarChar(255)

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  users           User[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  supportTickets  SupportTicket[]

  inventoryItems  InventoryItem[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  inventoryBatches InventoryBatch[]
  stockMovements  StockMovement[]

  @@map("tenants")
}

model User {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String?         @map("tenant_id") @db.Uuid
  name         String          @db.VarChar(255)
  email        String          @db.VarChar(255)
  passwordHash String          @map("password_hash") @db.VarChar(255)
  role         String          @default("tenant") @db.VarChar(50)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tickets      SupportTicket[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(100)
  sortOrder Int?      @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([tenantId])
  @@map("categories")
}

model Product {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  categoryId      String?             @map("category_id") @db.Uuid
  name            String              @db.VarChar(255)
  description     String?             @db.Text
  price           Decimal             @db.Decimal(10, 2)
  imageUrl        String?             @map("image_url") @db.Text
  productType     String              @default("simple") @map("product_type") @db.VarChar(50)
  isActive        Boolean?            @default(true) @map("is_active")
  autoDeductStock Boolean?            @default(true) @map("auto_deduct_stock")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  components      ProductComponent[]
  choiceGroups    ProductChoiceGroup[]
  recipes         ProductRecipe[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("products")
}

model ProductComponent {
  id              String       @id @default(uuid()) @db.Uuid
  productId       String       @map("product_id") @db.Uuid
  name            String       @db.VarChar(255)
  inventoryItemId String?      @map("inventory_item_id") @db.Uuid
  quantity        Decimal      @default(1) @db.Decimal(12, 3)
  price           Decimal      @default(0) @db.Decimal(10, 2)
  includedInPrice Boolean      @default(true) @map("included_in_price")
  deductStock     Boolean      @default(true) @map("deduct_stock")
  isDefault       Boolean      @default(true) @map("is_default")
  sortOrder       Int?         @default(0) @map("sort_order")
  createdAt       DateTime     @default(now()) @map("created_at")

  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("product_components")
}

model ProductChoiceGroup {
  id          String                @id @default(uuid()) @db.Uuid
  productId   String                @map("product_id") @db.Uuid
  name        String                @db.VarChar(255)
  minChoices  Int                   @default(0) @map("min_choices")
  maxChoices  Int                   @default(1) @map("max_choices")
  required    Boolean               @default(false)
  sortOrder   Int?                  @default(0) @map("sort_order")
  createdAt   DateTime              @default(now()) @map("created_at")

  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  options     ProductChoiceOption[]

  @@index([productId])
  @@map("product_choice_groups")
}

model ProductChoiceOption {
  id              String             @id @default(uuid()) @db.Uuid
  choiceGroupId   String             @map("choice_group_id") @db.Uuid
  name            String             @db.VarChar(255)
  inventoryItemId String?            @map("inventory_item_id") @db.Uuid
  quantity        Decimal            @default(1) @db.Decimal(12, 3)
  price           Decimal            @default(0) @db.Decimal(10, 2)
  includedInPrice Boolean            @default(false) @map("included_in_price")
  deductStock     Boolean            @default(true) @map("deduct_stock")
  isDefault       Boolean            @default(false) @map("is_default")
  sortOrder       Int?               @default(0) @map("sort_order")
  createdAt       DateTime           @default(now()) @map("created_at")

  choiceGroup     ProductChoiceGroup @relation(fields: [choiceGroupId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([choiceGroupId])
  @@map("product_choice_options")
}

model InventoryItem {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  name            String              @db.VarChar(255)
  unit            String              @default("un") @db.VarChar(20)
  currentStock    Decimal             @default(0) @map("current_stock") @db.Decimal(12, 3)
  minStock        Decimal             @default(0) @map("min_stock") @db.Decimal(12, 3)
  averageCost     Decimal?            @default(0) @map("average_cost") @db.Decimal(10, 4)
  referenceCost   Decimal?            @default(0) @map("reference_cost") @db.Decimal(10, 4)
  markup          Decimal?            @default(2.50) @db.Decimal(5, 2)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches         InventoryBatch[]
  recipes         ProductRecipe[]
  stockMovements  StockMovement[]
  purchaseItems   PurchaseOrderItem[]
  productComponents ProductComponent[]
  productChoiceOptions ProductChoiceOption[]

  @@index([tenantId])
  @@map("inventory_items")
}

model Supplier {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  name            String              @db.VarChar(255)
  phone           String?             @db.VarChar(50)
  email           String?             @db.VarChar(255)
  address         String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders  PurchaseOrder[]
  batches         InventoryBatch[]

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @map("tenant_id") @db.Uuid
  supplierId      String?               @map("supplier_id") @db.Uuid
  status          String                @default("pending") @db.VarChar(50)
  totalCost       Decimal               @default(0) @map("total_cost") @db.Decimal(10, 2)
  notes           String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at")
  receivedAt      DateTime?             @map("received_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items           PurchaseOrderItem[]
  batches         InventoryBatch[]

  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String          @id @default(uuid()) @db.Uuid
  purchaseOrderId   String          @map("purchase_order_id") @db.Uuid
  inventoryItemId   String          @map("inventory_item_id") @db.Uuid
  quantity          Decimal         @db.Decimal(12, 3)
  unitCost          Decimal         @map("unit_cost") @db.Decimal(10, 4)
  expirationDate    DateTime?       @db.Date @map("expiration_date")
  manufacturingDate DateTime?       @db.Date @map("manufacturing_date")

  purchaseOrder     PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model InventoryBatch {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  inventoryItemId   String          @map("inventory_item_id") @db.Uuid
  purchaseOrderId   String?         @map("purchase_order_id") @db.Uuid
  supplierId        String?         @map("supplier_id") @db.Uuid
  quantity          Decimal         @db.Decimal(12, 3)
  remainingQuantity Decimal         @map("remaining_quantity") @db.Decimal(12, 3)
  unitCost          Decimal         @map("unit_cost") @db.Decimal(10, 4)
  expirationDate    DateTime?       @db.Date @map("expiration_date")
  manufacturingDate DateTime?       @db.Date @map("manufacturing_date")
  createdAt         DateTime        @default(now()) @map("created_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  purchaseOrder     PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplier          Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements    StockMovement[]

  @@index([tenantId])
  @@index([inventoryItemId])
  @@index([expirationDate])
  @@map("inventory_batches")
}

model ProductRecipe {
  id              String          @id @default(uuid()) @db.Uuid
  productId       String          @map("product_id") @db.Uuid
  inventoryItemId String          @map("inventory_item_id") @db.Uuid
  quantity        Decimal         @db.Decimal(12, 3)

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryItemId])
  @@index([productId])
  @@map("product_recipes")
}

model StockMovement {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  inventoryItemId   String            @map("inventory_item_id") @db.Uuid
  inventoryBatchId  String?           @map("inventory_batch_id") @db.Uuid
  type              String            @db.VarChar(50)
  quantity          Decimal           @db.Decimal(12, 3)
  reason            String?           @db.Text
  orderId           String?           @map("order_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryBatch    InventoryBatch?   @relation(fields: [inventoryBatchId], references: [id], onDelete: SetNull)
  order             Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([inventoryItemId])
  @@map("stock_movements")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  customerName    String      @map("customer_name") @db.VarChar(255)
  customerPhone   String      @map("customer_phone") @db.VarChar(50)
  status          String      @default("pending") @db.VarChar(50)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress String?     @map("delivery_address") @db.Text
  paymentMethod   String?     @map("payment_method") @db.VarChar(100)
  stockDeducted   Boolean?    @default(false) @map("stock_deducted")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  stockMovements  StockMovement[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String                 @id @default(uuid()) @db.Uuid
  orderId     String                 @map("order_id") @db.Uuid
  productId   String                 @map("product_id") @db.Uuid
  quantity    Int
  unitPrice   Decimal                @map("unit_price") @db.Decimal(10, 2)
  notes       String?                @db.Text

  order       Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  components  OrderItemComponent[]
  choices     OrderItemChoice[]

  @@index([orderId])
  @@map("order_items")
}

model OrderItemComponent {
  id              String       @id @default(uuid()) @db.Uuid
  orderItemId     String       @map("order_item_id") @db.Uuid
  componentId     String       @map("component_id") @db.Uuid
  name            String       @db.VarChar(255)
  quantity        Int
  unitPrice       Decimal      @map("unit_price") @db.Decimal(10, 2)
  inventoryItemId String?      @map("inventory_item_id") @db.Uuid
  deductStock     Boolean      @default(true) @map("deduct_stock")

  orderItem       OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_components")
}

model OrderItemChoice {
  id              String       @id @default(uuid()) @db.Uuid
  orderItemId     String       @map("order_item_id") @db.Uuid
  choiceGroupId   String       @map("choice_group_id") @db.Uuid
  choiceGroupName String       @map("choice_group_name") @db.VarChar(255)
  optionId        String       @map("option_id") @db.Uuid
  optionName      String       @map("option_name") @db.VarChar(255)
  quantity        Int
  unitPrice       Decimal      @map("unit_price") @db.Decimal(10, 2)
  inventoryItemId String?      @map("inventory_item_id") @db.Uuid
  deductStock     Boolean      @default(true) @map("deduct_stock")

  orderItem       OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_choices")
}

model SupportTicket {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  subject     String          @db.VarChar(255)
  description String          @db.Text
  status      String          @default("open") @db.VarChar(50)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([tenantId])
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(uuid()) @db.Uuid
  ticketId   String        @map("ticket_id") @db.Uuid
  senderRole String        @map("sender_role") @db.VarChar(50)
  message    String        @db.Text
  createdAt  DateTime      @default(now()) @map("created_at")

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

model GlobalAnnouncement {
  id        String    @id @default(uuid()) @db.Uuid
  message   String    @db.Text
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  @@map("global_announcements")
}
