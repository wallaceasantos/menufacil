# ==========================================
# Obrigatórias em produção
# ==========================================

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/menufacil_db

# Segurança — use uma string longa e aleatória
JWT_SECRET=change-me-to-a-random-string-with-at-least-32-characters

# URL pública da aplicação (usada em links de e-mail, convites e CORS)
APP_URL=http://localhost:3000

# URL da API no frontend. Use /api quando backend e frontend
# rodarem no mesmo domínio (Railway single-service).
VITE_API_URL=http://localhost:3001/api

# Cloudinary — uploads de imagens, anexos e boletos
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Mercado Pago — pagamentos reais
MP_ACCESS_TOKEN=TEST-xxx
MP_WEBHOOK_SECRET=your-webhook-secret
MP_WEBHOOK_URL=https://your-app.up.railway.app
MP_LOCAL_MODE=true

# Web Push
VAPID_PUBLIC_KEY=generate-with-web-push
VAPID_PRIVATE_KEY=generate-with-web-push

# ==========================================
# Opcionais
# ==========================================

# Preço de teste para pagamentos no modo local
MP_TEST_PRICE=10

# SMTP — notificações por e-mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-app.com

# Porta do servidor (Railway define automaticamente)
PORT=3001

# Seed do admin inicial (executado com: npx prisma db seed)
ADMIN_EMAIL=admin@menufacil.com
ADMIN_INITIAL_PASSWORD=change-me-in-production
